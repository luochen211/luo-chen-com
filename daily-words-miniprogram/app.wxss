page {
  --green: #087443;
  --green-dark: #075332;
  --green-soft: #e9f5ec;
  --yellow: #ffd452;
  --ink: #121b17;
  --muted: #7b817e;
  min-height: 100%;
  background: #f8f7f2;
  color: var(--ink);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", sans-serif;
}
button { font: inherit; }
button::after { border: 0; }
.page { min-height: 100vh; padding: 0 32rpx 44rpx; box-sizing: border-box; }
.custom-nav { height: 176rpx; padding-top: env(safe-area-inset-top); display: flex; align-items: flex-end; justify-content: center; padding-bottom: 24rpx; box-sizing: border-box; position: relative; }
.custom-nav__back, .custom-nav__action { position: absolute; bottom: 18rpx; width: 72rpx; height: 64rpx; display: grid; place-items: center; background: transparent; padding: 0; font-size: 46rpx; }
.custom-nav__back { left: 0; width: 116rpx; display: flex; align-items: center; justify-content: center; gap: 5rpx; border: 1rpx solid #d9e6de; border-radius: 34rpx; background: rgba(255,255,255,.92); color: #315d49; font-size: 24rpx; font-weight: 650; box-shadow: 0 5rpx 14rpx rgba(30,76,53,.08); }.custom-nav__back:active { background: #e9f5ec; transform: scale(.97); }.custom-nav__action { right: 0; font-size: 36rpx; }
.custom-nav__back image { width: 30rpx; height: 30rpx; }.custom-nav__action image { width: 42rpx; height: 42rpx; }
.custom-nav__title { font-size: 32rpx; font-weight: 700; }
.card { background: rgba(255,255,255,.94); border-radius: 30rpx; box-shadow: 0 10rpx 30rpx rgba(59,58,48,.09); }
.primary { width: 100%; height: 112rpx; border-radius: 56rpx; color: #fff; background: linear-gradient(135deg,#158b59,#006b3b); font-size: 38rpx; font-weight: 700; box-shadow: 0 12rpx 26rpx rgba(0,105,59,.2); }
.primary:active { transform: scale(.985); opacity: .94; }
