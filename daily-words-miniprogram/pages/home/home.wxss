.home-page { padding-bottom: 150rpx; }
.home-heading { display:flex; justify-content:space-between; align-items:center; margin: -36rpx 12rpx 36rpx; font-size:44rpx; font-weight:800; color:#06482d; }
.capsule { color:#111; font-size:30rpx; font-weight:600; background:#fff; border:1rpx solid #ddd; border-radius:40rpx; padding:14rpx 22rpx; letter-spacing:4rpx; }
.streak-card { height:328rpx; position:relative; padding:48rpx 36rpx 30rpx; box-sizing:border-box; overflow:hidden; border-radius:34rpx; color:#fff; background:radial-gradient(circle at 72% 46%,rgba(102,192,116,.42),transparent 32%),linear-gradient(135deg,#23875d,#03633d); box-shadow:0 12rpx 30rpx rgba(5,97,58,.24); }
.streak-copy { display:flex; flex-direction:column; gap:14rpx; }.streak-copy text { font-size:34rpx; }.streak-copy .strong { color:#ffe36c; font-size:62rpx; }.streak-copy .small { font-size:25rpx; }
.plant { position:absolute; right:68rpx; top:72rpx; width:110rpx; height:145rpx; transform-origin:bottom; animation:breathe 3.2s ease-in-out infinite; }.plant .strong { position:absolute; bottom:0; left:28rpx; width:66rpx; height:60rpx; border-radius:8rpx 8rpx 22rpx 22rpx; background:linear-gradient(90deg,#ffbe31,#ffd765); box-shadow:inset -8rpx 0 rgba(220,143,12,.3); }.stem { position:absolute; left:60rpx; top:25rpx; width:7rpx; height:72rpx; background:#5aa334; transform:rotate(3deg); }.leaf { position:absolute; width:50rpx; height:27rpx; border-radius:100% 0 100% 0; background:linear-gradient(135deg,#b4dc42,#4c9f30); transform-origin:100% 100%; }.leaf-1{left:15rpx;top:28rpx;transform:rotate(28deg)}.leaf-2{right:0;top:14rpx;transform:rotate(100deg)}.leaf-3{left:8rpx;top:64rpx;transform:rotate(18deg)}.leaf-4{right:0;top:53rpx;transform:rotate(110deg)}
.days { position:absolute; left:30rpx; right:30rpx; bottom:26rpx; display:flex; justify-content:space-between; }.days:before { content:""; position:absolute; top:19rpx; left:25rpx; right:25rpx; height:4rpx; background:rgba(255,255,255,.48); }.day { display:flex; flex-direction:column; align-items:center; gap:8rpx; font-size:20rpx; z-index:1; }.day .em { width:39rpx;height:39rpx;display:grid;place-items:center;border-radius:50%;background:rgba(255,255,255,.3);font-style:normal;font-weight:800; }.day.today { color:#ffdf55;font-weight:700}.day.today .em{background:#fff;color:#174b36}.day text{font-size:19rpx}
.goal-card { margin-top:26rpx; padding:34rpx 26rpx 30rpx; }.goal-head{display:flex;justify-content:space-between;align-items:center;font-size:29rpx}.goal-head button{margin:0;padding:0;background:transparent;color:#777;font-size:24rpx}.progress-ring{width:330rpx;height:330rpx;margin:24rpx auto 12rpx;border-radius:50%;background:conic-gradient(#0a7c49 var(--progress),#dcebe1 0);display:grid;place-items:center;animation:ring-in .9s ease-out}.progress-ring:before{content:"";position:absolute;width:292rpx;height:292rpx;border-radius:50%;background:#fff}.progress-ring view{position:relative;display:flex;flex-direction:column;align-items:center;gap:8rpx}.progress-ring text{font-size:24rpx}.progress-ring .strong{font-size:72rpx;color:#063d28}.progress-ring .small{font-size:48rpx;color:#111}.goal-tip{text-align:center;margin:14rpx 0 36rpx;font-size:26rpx}.goal-tip .strong{color:#07814d}.tabbar{position:fixed;z-index:4;left:0;right:0;bottom:0;height:150rpx;padding-bottom:env(safe-area-inset-bottom);background:rgba(255,255,255,.97);display:flex;justify-content:space-around;border-top:1rpx solid #eee}.tabbar button{min-width:120rpx;margin:0;padding:12rpx 22rpx 12rpx;background:transparent;color:#8c928f;display:flex;flex-direction:column;align-items:center;justify-content:flex-start;gap:7rpx}.tabbar image{width:66rpx;height:66rpx}.tabbar text{font-size:22rpx;line-height:1.1;font-weight:500}.tabbar .active{color:#087443}.tabbar .active text{font-weight:700}
@keyframes breathe{50%{transform:rotate(2deg) scale(1.03)}}@keyframes ring-in{from{opacity:.3;transform:scale(.86) rotate(-15deg)}}
.goal-head button{display:flex;align-items:center;gap:8rpx}.goal-head button image{width:27rpx;height:27rpx}.goal-card .primary{display:flex;align-items:center;justify-content:center;gap:18rpx}.goal-card .primary image{width:38rpx;height:38rpx}
