.report-page{padding-bottom:54rpx}.report-hero{height:270rpx;border-radius:30rpx 30rpx 0 0;padding:45rpx 34rpx;box-sizing:border-box;display:flex;justify-content:space-between;background:linear-gradient(135deg,#edf8e8,#dff1e2)}.report-hero>view:first-child{display:flex;flex-direction:column;gap:18rpx}.report-hero .strong{font-size:35rpx}.report-hero text{font-size:24rpx}.report-hero .em{font-style:normal;color:#087443;font-size:33rpx}.trophy{width:180rpx;height:125rpx;border-radius:20rpx 20rpx 70rpx 70rpx;background:linear-gradient(145deg,#ffc927,#ec9b00);display:grid;place-items:center;box-shadow:inset 0 -13rpx rgba(176,105,0,.16),0 14rpx 20rpx rgba(160,116,11,.15);transform:rotate(-2deg)}.trophy .em{color:white;font-size:62rpx}.chart{margin-top:-4rpx;padding:34rpx 30rpx 28rpx}.chart-title{font-size:28rpx;font-weight:700}.chart-title text{color:#888;font-weight:400}.bars{height:270rpx;margin-top:25rpx;border-bottom:1rpx solid #ddd;display:flex;align-items:stretch;justify-content:space-around;background:repeating-linear-gradient(to bottom,#eee 0,#eee 1rpx,transparent 1rpx,transparent 64rpx)}.bars>.bar-item{width:11%;height:100%;display:flex;flex-direction:column;align-items:center;justify-content:flex-end;gap:7rpx}.bars .strong{flex:none;font-size:19rpx;line-height:1}.bars .bar{flex:none;width:31rpx;border-radius:7rpx 7rpx 0 0;background:linear-gradient(#23945a,#05653b);animation:bar-in .8s ease-out both;transform-origin:bottom}.bars .bar-label{flex:none;white-space:nowrap;font-size:18rpx;line-height:27rpx;color:#666;margin-bottom:-27rpx}.stats{margin-top:24rpx;display:grid;grid-template-columns:1fr 1fr;overflow:hidden}.stats>view{height:133rpx;display:flex;align-items:center;gap:20rpx;padding:0 30rpx;box-sizing:border-box;border-right:1rpx solid #eee;border-bottom:1rpx solid #eee}.stats>view:nth-child(even){border-right:0}.stats .em{font-style:normal;font-size:47rpx}.stats text{display:flex;flex-direction:column;font-size:23rpx}.stats .strong{font-size:39rpx}.report-note{text-align:center;color:#8a928c;font-size:22rpx;margin-top:34rpx}@keyframes bar-in{from{transform:scaleY(0)}}
.trophy image{width:72rpx;height:72rpx}.bars .bar{display:block;width:31rpx;border-radius:7rpx 7rpx 0 0;background:linear-gradient(#23945a,#05653b);animation:bar-in .8s ease-out both;transform-origin:bottom}.stats image{width:45rpx;height:45rpx}.report-note{display:flex;align-items:center;justify-content:center;gap:12rpx}.report-note image{width:27rpx;height:27rpx}
