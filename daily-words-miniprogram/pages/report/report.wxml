<view class="page report-page">
  <custom-nav title="本周学习报告" back="{{true}}" action="分享" bind:action="share" />
  <view class="report-hero">
    <view><text class="strong">太棒了！</text><text>你本周的学习表现</text><text>超越了 <text class="em">92%</text> 的学习者</text></view>
    <view class="trophy"><image src="/assets/icons/trophy.png"/></view>
  </view>
  <view class="chart card"><view class="chart-title">学习概况 <text>({{dateRange}})</text></view><view class="bars"><view class="bar-item" wx:for="{{bars}}" wx:key="day"><text class="strong">{{item.value}}</text><view class="bar" style="height:{{item.height}}rpx"></view><text class="bar-label">{{item.day}}</text></view></view></view>
  <view class="stats card"><view wx:for="{{stats}}" wx:key="label"><image src="{{item.icon}}"/><text>{{item.label}}<text class="strong">{{item.value}}</text></text></view></view>
  <view class="report-note"><image src="/assets/icons/sparkles.png"/>积累每一个单词，遇见更好的自己。<image src="/assets/icons/sparkles.png"/></view>
</view>
