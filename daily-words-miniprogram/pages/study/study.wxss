.count{text-align:right;color:#7e817f;font-size:24rpx;margin:-18rpx 4rpx 18rpx}.word-card{height:820rpx;padding:50rpx 54rpx;box-sizing:border-box;position:relative;display:flex;flex-direction:column}.favorite{position:absolute;right:30rpx;top:30rpx;background:transparent;color:#d9d9d2;font-size:47rpx;padding:0}.favorite.on{color:#f7b800}.word-main{margin-top:90rpx}.word-main>text{font-family:Georgia,serif;color:#064a32;font-size:67rpx;font-weight:700}.word-main view{margin-top:28rpx;font-size:29rpx}.word-main button{display:inline-grid;place-items:center;width:58rpx;height:58rpx;margin-left:15rpx;border-radius:50%;background:#eaf5ec;font-size:26rpx;padding:0}.divider{height:1rpx;background:#ddd;margin:42rpx 0}.word-card .label{color:#8b8e8c;font-size:26rpx;margin-bottom:16rpx}.meaning{font-size:31rpx;font-weight:600;margin-bottom:55rpx}.example{font-size:29rpx;line-height:1.7}.example .strong{color:#087443}.pager{margin-top:auto;text-align:center;color:#ddd;letter-spacing:8rpx}.study-actions{display:flex;gap:52rpx;margin-top:48rpx}.study-actions button{flex:1;height:108rpx;border-radius:40rpx;background:#e9f5ec;color:#087443;font-size:31rpx;box-shadow:0 8rpx 22rpx rgba(31,73,50,.1)}.study-actions .strong{font-size:42rpx;margin-right:16rpx}.study-actions .unknown{background:#fff0ec;color:#d73a32}.swipe{text-align:center;color:#898c89;font-size:24rpx;margin-top:44rpx}
.favorite{width:64rpx;height:64rpx;display:grid;place-items:center}.favorite image{width:46rpx;height:46rpx}.word-main button image{width:32rpx;height:32rpx}.study-actions button{background:#087443;color:#fff;display:flex;align-items:center;justify-content:center;gap:14rpx}.study-actions image{width:36rpx;height:36rpx}
.word-main button.playing{background:#087443}.word-main button.playing image{filter:brightness(0) invert(1);animation:sound-pulse .8s ease-in-out infinite alternate}@keyframes sound-pulse{from{transform:scale(.9)}to{transform:scale(1.12)}}
