<view class="page quiz-page">
  <custom-nav title="单词挑战" back="{{true}}" />
  <view class="quiz-progress"><view><text class="progress-fill" style="width:{{current/total*100}}%"/></view><text class="strong">{{current}}<text class="small">/{{total}}</text></text></view>
  <view class="question" wx:if="{{question}}">“{{question.word}}” 的意思是？</view>
  <view class="options"><button wx:for="{{options}}" wx:key="letter" data-index="{{index}}" bindtap="select" disabled="{{answered}}" class="{{item.state}}"><text class="em">{{item.letter}}</text><text class="option-text">{{item.text}}</text><text class="option-mark" wx:if="{{item.mark}}">{{item.mark}}</text></button></view>
  <view wx:if="{{answered}}" class="feedback {{correct?'feedback-correct':'feedback-wrong'}}"><text class="feedback-mark">{{correct?'✓':'×'}}</text><text>{{feedback}}</text></view>
  <button class="primary next" bindtap="next" disabled="{{!answered}}">{{current>=total?'查看结果':'下一题'}}</button>
</view>
