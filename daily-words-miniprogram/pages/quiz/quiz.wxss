.quiz-progress{display:flex;align-items:center;gap:38rpx;margin:30rpx 14rpx 95rpx}.quiz-progress>view{height:14rpx;flex:1;background:#e2e1dd;border-radius:10rpx;overflow:hidden}.quiz-progress .progress-fill{display:block;height:100%;background:#3c9a61;border-radius:10rpx}.quiz-progress>.strong{color:#087443;font-size:40rpx}.quiz-progress .small{color:#333;font-size:27rpx}.question{font-size:38rpx;font-weight:750;margin:0 12rpx 55rpx}.options{display:flex;flex-direction:column;gap:25rpx}.options button{width:100%;min-height:120rpx;height:auto;margin:0;padding:24rpx 30rpx;box-sizing:border-box;display:flex;align-items:center;gap:28rpx;background:#fff;border-radius:26rpx;box-shadow:0 8rpx 22rpx rgba(58,56,48,.09);font-size:27rpx;line-height:1.5;text-align:left;white-space:normal}.options .em{font-style:normal;width:62rpx;height:62rpx;flex:none;display:grid;place-items:center;border-radius:50%;background:#e7f4e9;color:#126342}.options .option-text{min-width:0;flex:1;overflow-wrap:break-word}.options .strong{width:55rpx;height:55rpx;flex:none;display:grid;place-items:center;border-radius:50%;background:#087443;color:white}.options .selected{border:3rpx solid #087443;color:#08603a}.next{margin-top:110rpx}.next[disabled]{opacity:.45}
