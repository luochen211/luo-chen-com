.quiz-progress{display:flex;align-items:center;gap:38rpx;margin:30rpx 14rpx 95rpx}.quiz-progress>view{height:14rpx;flex:1;background:#e2e1dd;border-radius:10rpx;overflow:hidden}.quiz-progress .progress-fill{display:block;height:100%;background:#3c9a61;border-radius:10rpx}.quiz-progress>.strong{color:#087443;font-size:40rpx}.quiz-progress .small{color:#333;font-size:27rpx}.question{font-size:38rpx;font-weight:750;margin:0 12rpx 55rpx}.options{display:flex;flex-direction:column;gap:25rpx}.options button{width:100%;min-height:120rpx;height:auto;margin:0;padding:24rpx 30rpx;box-sizing:border-box;display:flex;align-items:center;gap:28rpx;background:#fff;border:3rpx solid transparent;border-radius:26rpx;box-shadow:0 8rpx 22rpx rgba(58,56,48,.09);font-size:27rpx;line-height:1.5;text-align:left;white-space:normal}.options button[disabled]{opacity:1;color:inherit}.options .em{font-style:normal;width:62rpx;height:62rpx;flex:none;display:grid;place-items:center;border-radius:50%;background:#e7f4e9;color:#126342}.options .option-text{min-width:0;flex:1;overflow-wrap:break-word}.options .option-mark{width:55rpx;height:55rpx;flex:none;display:grid;place-items:center;border-radius:50%;background:#087443;color:#fff;font-size:32rpx;font-weight:700}.options .correct{border-color:#087443;background:#f5fbf7;color:#08603a}.options .wrong{border-color:#d8473f;background:#fff7f5;color:#a82e29}.options .wrong .em{background:#fde4df;color:#b3362f}.options .wrong .option-mark{background:#d8473f}.options .muted{opacity:.58}.feedback{min-height:76rpx;margin:28rpx 8rpx 0;padding:18rpx 24rpx;box-sizing:border-box;display:flex;align-items:center;gap:16rpx;border-radius:20rpx;font-size:26rpx;font-weight:600;line-height:1.4}.feedback-mark{width:38rpx;height:38rpx;flex:none;display:grid;place-items:center;border-radius:50%;color:#fff}.feedback-correct{background:#e8f5ec;color:#087443}.feedback-correct .feedback-mark{background:#087443}.feedback-wrong{background:#fff0ed;color:#a82e29}.feedback-wrong .feedback-mark{background:#d8473f}.next{margin-top:46rpx}.next[disabled]{opacity:.45}
